generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER  @map("owner")
  MEMBER @map("member")

  @@map("workspace_role")
}

enum TriageStatus {
  PENDING   @map("pending")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
  ENRICHING @map("enriching")
  ENRICHED  @map("enriched")

  @@map("triage_status")
}

enum IssueSource {
  WEBHOOK   @map("webhook")
  JIRA_SYNC @map("jira_sync")

  @@map("issue_source")
}

enum IssueComplexity {
  LOW    @map("low")
  MEDIUM @map("medium")
  HIGH   @map("high")

  @@map("issue_complexity")
}

enum IssueStatus {
  DRAFT  @map("draft")
  PUSHED @map("pushed")

  @@map("issue_status")
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  email          String   @unique
  hashedPassword String   @map("hashed_password")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspaces       Workspace[]
  workspaceMembers WorkspaceMember[]
  refreshTokens    RefreshToken[]

  @@map("users")
}

model Workspace {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String
  slug                  String   @unique
  ownerId               String   @map("owner_id") @db.Uuid
  jiraBaseUrl           String?  @map("jira_base_url")
  jiraEmail             String?  @map("jira_email")
  jiraApiTokenEncrypted String?  @map("jira_api_token_encrypted")
  jiraProjectKey        String?  @map("jira_project_key")
  githubRepo            String?  @map("github_repo")
  githubTokenEncrypted  String?  @map("github_token_encrypted")
  assigneeMapping       Json     @default("{}") @map("assignee_mapping")
  ollamaUrl             String   @default("http://localhost:11434") @map("ollama_url")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner          User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members        WorkspaceMember[]
  webhookSources WebhookSource[]
  triageItems    TriageItem[]
  issues         Issue[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        WorkspaceRole @default(OWNER)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId], map: "uq_workspace_member")
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash") @db.VarChar(64)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model WebhookSource {
  id             String    @id @default(uuid()) @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  name           String
  apiKeyHash     String    @map("api_key_hash")
  fieldMapping   Json      @default("{}") @map("field_mapping")
  callbackUrl    String?   @map("callback_url")
  lastReceivedAt DateTime? @map("last_received_at") @db.Timestamptz(6)
  payloadCount   Int       @default(0) @map("payload_count")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  triageItems TriageItem[]

  @@index([workspaceId])
  @@map("webhook_sources")
}

model TriageItem {
  id              String       @id @default(uuid()) @db.Uuid
  workspaceId     String       @map("workspace_id") @db.Uuid
  webhookSourceId String?      @map("webhook_source_id") @db.Uuid
  rawPayload      Json         @map("raw_payload")
  title           String?
  description     String?
  reporter        String?
  status          TriageStatus @default(PENDING)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  webhookSource WebhookSource? @relation(fields: [webhookSourceId], references: [id], onDelete: SetNull)
  issues        Issue[]

  @@index([workspaceId])
  @@index([webhookSourceId])
  @@index([status])
  @@map("triage_items")
}

model Issue {
  id                String           @id @default(uuid()) @db.Uuid
  workspaceId       String           @map("workspace_id") @db.Uuid
  triageItemId      String?          @map("triage_item_id") @db.Uuid
  source            IssueSource
  title             String
  description       String
  affectedFiles     Json             @default("[]") @map("affected_files")
  complexity        IssueComplexity?
  priority          String?
  reporter          String?
  suggestedAssignee String?          @map("suggested_assignee")
  reasoning         String?
  jiraKey           String?          @map("jira_key")
  status            IssueStatus      @default(DRAFT)
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  triageItem TriageItem? @relation(fields: [triageItemId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([jiraKey])
  @@index([status])
  @@map("issues")
}
