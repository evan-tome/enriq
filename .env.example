# --- App ---
NODE_ENV=development
PORT=8000

# --- Postgres ---
POSTGRES_USER=enriq
POSTGRES_PASSWORD=enriq_dev_password
POSTGRES_DB=enriq
DATABASE_URL=postgresql://enriq:enriq_dev_password@postgres:5432/enriq

# --- Ollama ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=codellama

# --- JWT / Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
ACCESS_TOKEN_EXPIRES_MINUTES=15
REFRESH_TOKEN_EXPIRES_DAYS=7

# --- Refresh token cookie ---
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_PATH=/auth
COOKIE_SECURE=false

# --- Encryption (for jira/github token columns) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=replace-with-generated-key

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- Rate limiting (requests per minute) ---
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_REGISTER_MAX=3

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8000
